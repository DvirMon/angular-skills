{
  "buildCommand": "node scripts/build-wellknown.mjs",
  "outputDirectory": "public",
  "framework": null,
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
